ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://adops:adops@localhost:5432/adops_signal
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
AUTH_ENABLED=true
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEMO_ADMIN_EMAIL=adops@demo.adops.local
DEMO_ADMIN_PASSWORD=SignalDemo!2026
SEED_DEMO_DATA=true
LOG_LEVEL=INFO

# Optional for local use. When set, diagnosis uses structured LLM reasoning.
# Without it, the app remains available through the grounded fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=25
LLM_ENABLED=true

# Set to openai to index and query playbooks with text-embedding-3-small.
RAG_EMBEDDING_PROVIDER=local
RAG_EMBEDDING_MODEL=text-embedding-3-small
